# Core database settings
POSTGRES_DB=bantay
POSTGRES_USER=bantay
POSTGRES_PASSWORD=bantay
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Backend app secrets/admin
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass
ADMIN_NAME=Admin
ADMIN_CREATE_ON_STARTUP="true"

# Backend <-> Traccar integration
TRACCAR_API_URL=http://traccar:8082
TRACCAR_API_TOKEN=
TRACCAR_SHARED_SECRET=change-me

# Traccar DB credentials
TRACCAR_DB_USER=traccar
TRACCAR_DB_PASSWORD=traccar

# Traccar forwarding
TRACCAR_FORWARD_ENABLE=true
TRACCAR_FORWARD_URL=http://backend:8000/api/traccar/positions
TRACCAR_FORWARD_TYPE=json
TRACCAR_EVENT_FORWARD_ENABLE=true
TRACCAR_EVENT_FORWARD_URL=http://backend:8000/api/traccar/events
TRACCAR_EVENT_FORWARD_TYPE=json

# Long-lived session (1 year in ms by default)
TRACCAR_SESSION_TIMEOUT_MS=31536000000

# Traccar admin bootstrapping (used by traccar-init)
TRACCAR_ADMIN_EMAIL=admin@example.com
TRACCAR_ADMIN_PASSWORD=changeme
TRACCAR_ADMIN_NAME=Admin
TRACCAR_DEFAULT_PASSWORD=admin